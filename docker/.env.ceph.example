# Ceph 对象存储配置示例
# 复制此文件为 .env 并修改相应的配置值

# 基础配置
APP_SPA_DOMAIN=http://localhost:8085
APP_SPA_PORT=8085

# 数据库配置
MONGO_URL=mongodb://localhost:27017/app-space

# 存储配置 - 设置为 ceph 启用 Ceph 对象存储
STORAGE_TYPE=ceph

# Ceph 对象存储配置
CEPH_ACCESS_KEY_ID=your_ceph_access_key_id
CEPH_SECRET_ACCESS_KEY=your_ceph_secret_access_key
CEPH_BUCKET_NAME=app-space-bucket
CEPH_ENDPOINT=http://your-ceph-rgw-host:7480
CEPH_REGION=us-east-1
CEPH_PREFIX=app-space
CEPH_DOWNLOAD_URL=http://your-ceph-rgw-host:7480/app-space-bucket

# JWT 配置
TOKEN_SECRET=your_jwt_secret_key_here

# 邮件配置（可选）
MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=
MAIL_USER=
MAIL_PASS=

# LDAP 配置（可选）
APP_SPA_ALLOW_LDAP=false
APP_SPA_LDAP_URL=
APP_SPA_LDAP_USERDN=
APP_SPA_LDAP_CREDENTIALS=
APP_SPA_LDAP_BASE=

# iOS 配置
IOS_PLIST_SOURCE=yun

# 其他存储配置（当 STORAGE_TYPE 不是 ceph 时使用）
# 本地存储
STORAGE_DIR=/data/storage

# 七牛云存储
QIN_IU_ACCESS_KEY=
QIN_IU_SECRET_KEY=
QIN_IU_BUCKET_NAME=
QIN_IU_DOWNLOAD_URL=

# 又拍云存储
UP_YUN_STORAGE_DIR=
UP_YUN_SERVICE_NAME=
UP_YUN_OPERATOR_NAME=
UP_YUN_OPERATOR_PASS=
UP_YUN_DOWNLOAD_URL=

# AWS S3 存储
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_BUCKET_NAME=
AWS_REGION=
AWS_DOWNLOAD_URL=

# 腾讯云存储
TENCENT_CLOUD_ACCESS_KEY_ID=
TENCENT_CLOUD_SECRET_ACCESS_KEY=
TENCENT_CLOUD_BUCKET_NAME=
TENCENT_CLOUD_REGION=
TENCENT_CLOUD_DOWNLOAD_URL=

# 阿里云 OSS 存储
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET_NAME=
OSS_ENDPOINT=
OSS_PREFIX=
OSS_DOWNLOAD_URL=
